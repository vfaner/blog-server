<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.0 http://maven.apache.org/xsd/assembly-2.1.0.xsd">
    <id>package</id>
    <formats>
        <format>tar.gz</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>

    <!-- 依赖的jar, 可以由外部替换 -->
    <!--
    <dependencySets>
        <dependencySet>
            <outputDirectory>lib</outputDirectory>
            <includes>
                <include>mysql:*</include>
            </includes>
            <fileMode>0544</fileMode>
        </dependencySet>
    </dependencySets>
    -->

    <fileSets>
        <!--创建一个空的lib目录（如果没有前面那个dependencySet）-->
        <fileSet>
            <outputDirectory>lib</outputDirectory>
            <excludes>
                <exclude>**/*</exclude>
            </excludes>
        </fileSet>
        <!-- 程序本身的jar -->
        <fileSet>
            <directory>target</directory>
            <outputDirectory>.</outputDirectory>
            <includes>
                <include>${project.build.finalName}-exec.jar</include>
            </includes>
            <fileMode>0755</fileMode>
        </fileSet>

        <!-- 程序的配置 -->
        <fileSet>
            <directory>src/main/resources</directory>
            <outputDirectory>config</outputDirectory>
            <includes>
                <!-- 不想打入一些测试用的配置文件 -->
                <include>application.properties</include>
                <include>logback-spring.xml</include>
                <include>system.json</include>
            </includes>
        </fileSet>
        <!-- 程序的配置 -->
        <fileSet>
            <directory>src/main/resources</directory>
            <outputDirectory>lib</outputDirectory>
            <includes>
                <!-- sql模板配置文件 -->
                <include>templates*/*</include>
                <!--                <include>logback.xml</include>-->
                <!--                <include>login.json</include>-->
            </includes>
        </fileSet>

        <!-- License -->
        <fileSet>
            <directory>../assembly/license</directory>
            <outputDirectory>license</outputDirectory>
            <includes>
                <include>*.xml</include>
            </includes>
        </fileSet>


        <!-- 程序的启动脚本 -->
        <fileSet>
            <directory>../assembly/bin</directory>
            <includes>
                <include>*.sh</include>
            </includes>
            <outputDirectory>bin</outputDirectory>
            <lineEnding>unix</lineEnding>
            <fileMode>0755</fileMode>
        </fileSet>

        <fileSet>
            <directory>../assembly/bin</directory>
            <includes>
                <include>*.bat</include>
            </includes>
            <outputDirectory>bin</outputDirectory>
            <lineEnding>windows</lineEnding>
        </fileSet>

        <!-- 程序的数据库脚本 -->
        <fileSet>
            <directory>../assembly/db-scripts</directory>
            <includes>
                <include>**/*</include>
            </includes>
            <outputDirectory>db-scripts</outputDirectory>
            <lineEnding>unix</lineEnding>
        </fileSet>
        <fileSet>
            <directory>target/generated-sources/db-scripts</directory>
            <includes>
                <include>**/*</include>
            </includes>
            <outputDirectory>db-scripts</outputDirectory>
            <lineEnding>unix</lineEnding>
        </fileSet>

        <!-- Dockerfile -->
        <fileSet>
            <directory>src/main/docker</directory>
            <includes>
                <include>*Dockerfile</include>
            </includes>
            <lineEnding>unix</lineEnding>
            <outputDirectory>.</outputDirectory>
        </fileSet>

        <fileSet>
            <includes>
                <include>README.md</include>
            </includes>
        </fileSet>
    </fileSets>
</assembly>